<% layout("/layouts/boilerplate") %>

<div class="wl-show">

  <!-- Back -->
  <a href="/listings" class="wl-show__back">
    <i class="fa-solid fa-arrow-left"></i> Back to all listings
  </a>

  <!-- Hero Image Gallery -->
  <div class="wl-show__img-gallery">
    <img src="<%= listing.image.url %>" alt="<%= listing.title %>" />
  </div>

  <!-- Two-column layout -->
  <div class="wl-show__grid">

    <!-- Left: Info + Reviews -->
    <div>
      <h1 class="wl-show__title"><%= listing.title %></h1>

      <div class="wl-show__meta">
        <div class="wl-show__meta-item">
          <i class="fa-solid fa-location-dot"></i>
          <span><%= listing.location %>, <%= listing.country %></span>
        </div>
        <div class="wl-show__meta-item">
          <i class="fa-solid fa-star"></i>
          <span>4.8 · <%= listing.reviews.length %> review<%= listing.reviews.length !== 1 ? 's' : '' %></span>
        </div>
      </div>

      <p class="wl-show__desc"><%= listing.description %></p>

      <!-- Action buttons (only for authenticated users) -->
      <div class="wl-show__actions">
        <a href="/listings/<%= listing._id %>/edit" class="wl-btn wl-btn--edit wl-btn--sm">
          <i class="fa-solid fa-pen-to-square"></i> Edit Listing
        </a>
        <a href="/listings/<%= listing._id %>/delete" class="wl-btn wl-btn--danger wl-btn--sm">
          <i class="fa-solid fa-trash"></i> Delete
        </a>
      </div>

      <!-- Reviews Section -->
      <div class="wl-reviews">
        <hr class="wl-section-divider" />
        <h2 style="font-size:1.5rem; margin-bottom:1.5rem;">
          <i class="fa-solid fa-star" style="color:var(--amber); font-size:1.1rem;"></i>
          4.8 · <%= listing.reviews.length %> Review<%= listing.reviews.length !== 1 ? 's' : '' %>
        </h2>

        <!-- Leave a Review Form -->
        <div class="wl-review-form">
          <h3 class="wl-review-form__title">
            <i class="fa-solid fa-pen" style="color:var(--amber); margin-right:0.4rem;"></i>
            Leave a Review
          </h3>
          <form method="POST" action="/listings/<%= listing._id %>/reviews">

            <!-- Star rating -->
            <div class="wl-form-group">
              <label class="wl-form-label">Your Rating</label>
              <fieldset class="starability-slot">
                <input type="radio" id="no-rate" class="input-no-rate" name="rating" value="0" checked aria-label="No rating." />
                <input type="radio" id="rate1" name="rating" value="1" />
                <label for="rate1" title="Terrible">1 star</label>
                <input type="radio" id="rate2" name="rating" value="2" />
                <label for="rate2" title="Not good">2 stars</label>
                <input type="radio" id="rate3" name="rating" value="3" />
                <label for="rate3" title="Average">3 stars</label>
                <input type="radio" id="rate4" name="rating" value="4" />
                <label for="rate4" title="Very good">4 stars</label>
                <input type="radio" id="rate5" name="rating" value="5" />
                <label for="rate5" title="Amazing">5 stars</label>
              </fieldset>
            </div>

            <!-- Comment -->
            <div class="wl-form-group">
              <label class="wl-form-label" for="comment">Your Comment</label>
              <textarea
                class="wl-form-textarea"
                name="comment"
                id="comment"
                required
                rows="3"
                placeholder="Share your experience with this property…"
              ></textarea>
            </div>

            <button type="submit" class="wl-btn wl-btn--primary">
              <i class="fa-solid fa-paper-plane"></i> Submit Review
            </button>
          </form>
        </div>

        <!-- Existing Reviews -->
        <% if (listing.reviews.length > 0) { %>
          <% listing.reviews.forEach(review => { %>
            <div class="wl-review-item">
              <div class="wl-review-item__header">
                <div>
                  <div class="wl-review-item__stars">
                    <% for (let i = 0; i < 5; i++) { %>
                      <i class="fa-<%= i < review.rating ? 'solid' : 'regular' %> fa-star"></i>
                    <% } %>
                  </div>
                </div>
                <span class="wl-review-item__date">
                  <i class="fa-regular fa-calendar" style="margin-right:0.3rem;"></i>
                  <%= new Date(review.createdAt).toLocaleDateString('en-IN', { year:'numeric', month:'short', day:'numeric' }) %>
                </span>
              </div>
              <p class="wl-review-item__comment"><%= review.comment %></p>
              <div style="margin-top:0.75rem; text-align:right;">
                <form action="/listings/<%= listing._id %>/deleteReview/<%= review._id %>" method="post" style="display:inline;">
                  <button type="submit" class="wl-btn wl-btn--danger wl-btn--sm">
                    <i class="fa-solid fa-trash"></i> Delete
                  </button>
                </form>
              </div>
            </div>
          <% }) %>
        <% } else { %>
          <div class="wl-empty-reviews">
            <i class="fa-regular fa-comment-dots" style="font-size:2rem; display:block; margin-bottom:0.75rem; opacity:0.4;"></i>
            No reviews yet — be the first to share your experience!
          </div>
        <% } %>
      </div>
    </div>

    <!-- Right: Booking card -->
    <div>
      <div class="wl-booking-card">
        <div class="wl-booking-card__price">
          ₹ <%= listing.price.toLocaleString("en-IN") %>
          <span>/ night</span>
        </div>
        <div style="display:flex; gap:0.3rem; color:var(--amber); font-size:0.85rem; margin-bottom:0.5rem;">
          <i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star-half-stroke"></i>
          <span style="color:var(--slate); margin-left:0.2rem;">4.8</span>
        </div>
        <hr class="wl-booking-card__divider" />
        <p style="font-size:0.82rem; color:var(--slate); line-height:1.6; margin-bottom:1.25rem;">
          <i class="fa-solid fa-circle-info" style="color:var(--amber); margin-right:0.35rem;"></i>
          Contact the host to check availability and confirm your booking.
        </p>
        <div class="wl-booking-card__actions">
          <a href="/listings/<%= listing._id %>/edit" class="wl-btn wl-btn--primary wl-btn--full">
            <i class="fa-solid fa-pen-to-square"></i> Edit This Listing
          </a>
          <a href="/listings/<%= listing._id %>/delete" class="wl-btn wl-btn--ghost wl-btn--full">
            <i class="fa-solid fa-trash"></i> Delete Listing
          </a>
        </div>
        <hr class="wl-booking-card__divider" />
        <div style="font-size:0.8rem; color:var(--slate); text-align:center;">
          <i class="fa-solid fa-shield-halved" style="color:var(--amber); margin-right:0.3rem;"></i>
          Your booking is protected by WanderLust
        </div>
      </div>
    </div>

  </div>
</div>
