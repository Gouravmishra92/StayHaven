<% layout("/layouts/boilerplate") %>

<div class="wl-form-page">
  <div class="wl-form-card wl-form-card--auth">

    <!-- Brand -->
    <div class="wl-form-card__brand">
      <div class="wl-form-card__brand-icon"><i class="fa-solid fa-compass"></i></div>
    </div>
    <h1 class="wl-form-card__title">Welcome back</h1>
    <p class="wl-form-card__subtitle">Sign in to your StayHaven account</p>

    <form action="/login" method="post" novalidate id="loginForm">

      <div class="wl-form-group">
        <label class="wl-form-label" for="username">Username</label>
        <input type="text" id="username" name="username" class="wl-form-input" placeholder="Your username" required autocomplete="username" />
      </div>

      <div class="wl-form-group">
        <label class="wl-form-label" for="password">Password</label>
        <input type="password" id="password" name="password" class="wl-form-input" placeholder="Your password" required autocomplete="current-password" />
      </div>

      <button type="submit" class="wl-btn wl-btn--primary wl-btn--full" style="margin-top:0.5rem; border-radius:var(--radius-md); padding:0.85rem;">
        <i class="fa-solid fa-right-to-bracket"></i> Log In
      </button>
    </form>

    <p class="wl-form-footer">
      Don't have an account? <a href="/signup">Sign up for free</a>
    </p>
  </div>
</div>
