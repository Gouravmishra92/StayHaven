<% layout("/layouts/boilerplate") %>

<div class="wl-form-page">
  <div class="wl-form-card wl-form-card--auth">

    <!-- Brand -->
    <div class="wl-form-card__brand">
      <div class="wl-form-card__brand-icon"><i class="fa-solid fa-user-plus"></i></div>
    </div>
    <h1 class="wl-form-card__title">Create your account</h1>
    <p class="wl-form-card__subtitle">Join StayHaven and start exploring</p>

    <form action="/signup" method="post" novalidate id="signupForm">

      <div class="wl-form-group">
        <label class="wl-form-label" for="username">Username</label>
        <input type="text" id="username" name="username" class="wl-form-input" placeholder="Choose a username" required autocomplete="username" />
      </div>

      <div class="wl-form-group">
        <label class="wl-form-label" for="email">Email Address</label>
        <input type="email" id="email" name="email" class="wl-form-input" placeholder="you@example.com" required autocomplete="email" />
      </div>

      <div class="wl-form-group">
        <label class="wl-form-label" for="password">Password</label>
        <input type="password" id="password" name="password" class="wl-form-input" placeholder="Create a strong password" required autocomplete="new-password" />
      </div>

      <button type="submit" class="wl-btn wl-btn--primary wl-btn--full" style="margin-top:0.5rem; border-radius:var(--radius-md); padding:0.85rem;">
        <i class="fa-solid fa-user-plus"></i> Create Account
      </button>
    </form>

    <p class="wl-form-footer">
      Already have an account? <a href="/login">Log in</a>
    </p>
  </div>
</div>
